generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  GHOSTED
}

enum CompanyType {
  STARTUP
  SCALEUP
  CORPORATE
  CONSULTORA
  AGENCY
  OTHER
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  NOT_SPECIFIED
}

enum ApplicationSource {
  LINKEDIN
  INFOJOBS
  INDEED
  COMPANY_SITE
  REFERRAL
  OTHER
}

model User {
  id              String               @id @default(uuid())
  email           String               @unique
  name            String?
  password        String
  createdAt       DateTime             @default(now())
  emailVerified   Boolean              @default(false)
  profile         UserProfile?
  tokens          VerificationToken[]
  jobApplications JobApplication[]
}

model VerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  targetRole      String
  experienceLevel ExperienceLevel
  yearsExperience Int?
  githubUrl       String?
  linkedinUrl     String?
  portfolioUrl    String?
  location        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          UserProfileSkill[]
}

model UserProfileSkill {
  id        String      @id @default(uuid())
  profileId String
  skillId   String
  level     SkillLevel?
  years     Int?
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill     Skill       @relation(fields: [skillId], references: [id])

  @@unique([profileId, skillId])
}

model Skill {
  id              String                @id @default(uuid())
  name            String                @unique
  categoryId      String?
  category        SkillCategory?        @relation(fields: [categoryId], references: [id])
  profiles        UserProfileSkill[]
  jobApplications JobApplicationSkill[]
  marketDemand    SkillDemand[]
  jobMarketSkills JobMarketSkill[]
  createdAt       DateTime              @default(now())
}

model SkillCategory {
  id     String  @id @default(uuid())
  name   String  @unique
  skills Skill[]
}

model JobApplication {
  id          String              @id @default(uuid())
  userId      String
  company     String
  role        String
  url         String?
  location    String?
  status      ApplicationStatus   @default(SAVED)
  source      ApplicationSource   @default(OTHER)
  companyType CompanyType?
  workMode    WorkMode?
  salaryMin   Int?
  salaryMax   Int?
  notes       String?
  appliedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills      JobApplicationSkill[]
}

model JobApplicationSkill {
  id            String         @id @default(uuid())
  applicationId String
  skillId       String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  skill         Skill          @relation(fields: [skillId], references: [id])

  @@unique([applicationId, skillId])
}


model JobMarket {
  id          String    @id @default(uuid())
  title       String
  company     String?
  location    String?
  workMode    WorkMode?
  salaryMin   Int?
  salaryMax   Int?
  source      String
  sourceUrl   String?   @unique
  publishedAt DateTime?
  scrapedAt   DateTime  @default(now())
  region    String?
  roleCategory String?
  skills      JobMarketSkill[]
}

model JobMarketSkill {
  id           String    @id @default(uuid())
  jobMarketId  String
  skillId      String
  jobMarket    JobMarket @relation(fields: [jobMarketId], references: [id], onDelete: Cascade)
  skill        Skill     @relation(fields: [skillId], references: [id])

  @@unique([jobMarketId, skillId])
}

model SkillDemand {
  id          String   @id @default(uuid())
  skillId     String
  region      String
  count       Int
  period      String   // ej: "2025-03", "2025-Q1"
  recordedAt  DateTime @default(now())
  skill       Skill    @relation(fields: [skillId], references: [id])

  @@unique([skillId, region, period])
}